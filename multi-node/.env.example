# Multi-node benchmark configuration
# Copy this file to .env and fill in your values

# SSH username for connecting to nodes
SSH_USER=ubuntu

# Node IPs (comma-separated, first node is the bootstrap + monitoring host)
# Examples:
#   Single validator:  NODE_IPS=1.2.3.1
#   Three validators:  NODE_IPS=1.2.3.1,1.2.3.2,1.2.3.3
NODE_IPS=1.2.3.1,1.2.3.2,1.2.3.3
